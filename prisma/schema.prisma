generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  name  String
  sueldo Float
  cumpleaños DateTime
  direccion String
  cedula String
  email String
  telefono String
  tareas   Tarea[]  
}

model Tarea {
  id          Int      @id @default(autoincrement())
  name        String
  descripcion String
  completada  Boolean  @default(false)  // ← agrega esto
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}